# Copy to .env and fill in.

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:your-telegram-bot-token
# Comma-separated Telegram user ids who may manage the knowledge base
ADMIN_IDS=111111111

# PostgreSQL with pgvector (matches docker-compose.yml)
DB_URL=postgresql+asyncpg://faq:faq@localhost:5432/faq

# OpenAI-compatible API. Leave OPENAI_BASE_URL empty for OpenAI; set it to a proxy
# aggregator endpoint where api.openai.com is unreachable.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=
CHAT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Retrieval tuning
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.3
